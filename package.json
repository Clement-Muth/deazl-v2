{
  "name": "deazl-v2",
  "version": "1.5.1",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "mobile": "bun run --cwd apps/mobile start",
    "typecheck": "bun run --cwd apps/web typecheck",
    "supabase:start": "bunx supabase start",
    "supabase:stop": "bunx supabase stop",
    "supabase:status": "bunx supabase status",
    "supabase:types": "bunx supabase gen types typescript --local > apps/web/src/lib/supabase/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2"
  }
}
