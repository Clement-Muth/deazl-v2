{
  "expo": {
    "name": "Deazl",
    "slug": "deazl",
    "version": "1.9.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "deazl",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.deazl.app",
      "buildNumber": "11"
    },
    "android": {
      "package": "fr.deazl.app",
      "versionCode": 11,
      "androidStatusBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#00000000"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8571C"
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Deazl utilise la caméra pour scanner les codes-barres des produits.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Deazl accède à vos photos pour personnaliser votre avatar."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Deazl utilise ta position pour trouver les magasins autour de toi."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
